<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <!-- Theme: applied immediately to avoid flash of wrong theme -->
  <script>
    (function () {
      function getCookie(name) {
        var m = document.cookie.match('(?:^|;)\\s*' + name + '=([^;]*)');
        return m ? decodeURIComponent(m[1]) : null;
      }
      var pref = getCookie('theme') || 'light';
      function applyTheme(p) {
        document.documentElement.classList.toggle(
          'dark',
          p === 'dark' || (p === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)
        );
      }
      applyTheme(pref);
      if (pref === 'system') {
        window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function () { applyTheme('system'); });
      }
    })();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- Prevent caching during development -->
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
  <meta http-equiv="Pragma" content="no-cache" />
  <meta http-equiv="Expires" content="0" />
  <title>{% block title %}Sunshine{% endblock %} — Therapy Dog Volunteers</title>
  <meta name="description" content="{% block description %}Connecting therapy dog teams with agencies across Southern Ontario.{% endblock %}" />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>☀️</text></svg>">
  
  <!-- PWA Manifest & Meta Tags -->
  <link rel="manifest" href="/static/manifest.json">
  <meta name="theme-color" content="#f59e0b">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Sunshine">
  <link rel="apple-touch-icon" href="/static/icons/icon-192.png">

  <!-- Tailwind CSS (CDN for dev; replace with compiled bundle in production) -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: {
        extend: {
          colors: {
            sunshine: {
              50:  '#fffbeb',
              100: '#fef3c7',
              200: '#fde68a',
              300: '#fcd34d',
              400: '#fbbf24',
              500: '#f59e0b',
              600: '#d97706',
              700: '#b45309',
              800: '#92400e',
              900: '#78350f',
            }
          }
        }
      }
    }
  </script>

  <!-- HTMX -->
  <script src="https://unpkg.com/htmx.org@1.9.12/dist/htmx.min.js"
          integrity="sha384-ujb1lZYygJmzgSwoxRggbCHcjc0rB2XoQrxeTUQyRjrOnlCoYta87iKBWq3EsdM2"
          crossorigin="anonymous" defer></script>
  <!-- Alpine.js (pinned to exact version; update integrity hash when upgrading) -->
  <script src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js"
          integrity="sha384-l8f0VcPi/M1iHPv8egOnY/15TDwqgbOR1anMIJWvU6nLRgZVLTLSaNqi/TOoT5Fh"
          crossorigin="anonymous" defer></script>
  
  <!-- PWA Offline Support (Dexie.js) -->
  <script src="https://unpkg.com/dexie@4.0.8/dist/dexie.min.js" defer></script>
  <script src="/static/js/db.js" defer></script>
  <script src="/static/js/sync.js" defer></script>

  <!-- Clerk JS (only loaded when Clerk auth is configured) -->
  {% set ck = clerk_publishable_key() %}
  {% set cjs = clerk_js_url() %}
  {% if ck and cjs %}
  <script
    data-clerk-publishable-key="{{ ck }}"
    src="{{ cjs }}"
    crossorigin="anonymous"
    async
    type="text/javascript"
  ></script>
  {% endif %}

  <!-- Dark mode overrides — loaded after Tailwind so specificity wins -->
  <link rel="stylesheet" href="/static/css/dark.css">

  {% block head %}{% endblock %}
  <style>
    /* Alpine.js - hide elements with x-cloak until Alpine initializes */
    [x-cloak] { display: none !important; }
    
    @keyframes pulse-slow {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.85; }
    }
    .animate-pulse-slow {
      animation: pulse-slow 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
  </style>
</head>
<body class="h-full bg-gray-50 text-gray-900 antialiased">

  <!-- Navigation -->
  <nav class="bg-sunshine-500 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 text-white font-bold text-xl tracking-tight">
          <span class="text-2xl">☀️</span>
          <span>Sunshine</span>
        </a>

        <!-- Nav links -->
        <div class="hidden md:flex items-center gap-6">
          {% if user %}
            {% if user.role == "volunteer" %}
              {% if volunteer_application_status %}
                <!-- Volunteer with incomplete application - restricted navigation -->
                <a href="/apply/status" class="text-white/90 hover:text-white text-sm font-medium flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  My Application
                </a>
                <a href="/volunteer/messages" class="text-white/90 hover:text-white text-sm font-medium flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z" />
                  </svg>
                  Messages
                </a>
              {% else %}
                <!-- Approved volunteer - full navigation -->
                <a href="/volunteer/shifts" class="text-white/90 hover:text-white text-sm font-medium">Upcoming Shifts</a>
                <a href="/volunteer/agenda" class="text-white/90 hover:text-white text-sm font-medium">My Agenda</a>
                <a href="/volunteer/dog-applications" class="text-white/90 hover:text-white text-sm font-medium">My Dogs</a>
                <a href="/volunteer/gallery" class="text-white/90 hover:text-white text-sm font-medium">Gallery</a>
                <a href="/volunteer/calendar" title="Calendar subscriptions"
                   class="text-white/70 hover:text-white transition-colors p-1 rounded-lg hover:bg-white/10">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                  </svg>
                </a>
                <a href="/volunteer/messages" class="text-white/90 hover:text-white text-sm font-medium">Messages</a>
                
                <!-- PWA Sync Indicator -->
                <div x-data="{ 
                      lastSync: localStorage.getItem('sunshine_last_synced_at'),
                      syncTimeStr: '',
                      updateSyncTime() {
                        if (!this.lastSync) { this.syncTimeStr = 'Never synced'; return; }
                        const mins = Math.floor((Date.now() / 1000 - this.lastSync) / 60);
                        this.syncTimeStr = mins < 1 ? 'Just now' : `${mins}m ago`;
                      }
                    }"
                    x-init="updateSyncTime(); setInterval(() => updateSyncTime(), 60000); window.addEventListener('sunshine-synced', () => { lastSync = localStorage.getItem('sunshine_last_synced_at'); updateSyncTime(); })"
                    class="ml-2 flex items-center gap-1.5 px-2 py-1 rounded-full bg-white/10 border border-white/20 text-[10px] text-white/80 font-bold uppercase tracking-widest shadow-inner">
                  <div class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></div>
                  <span x-text="syncTimeStr"></span>
                </div>
              {% endif %}
            {% elif user.role == "admin" %}
              <a href="/admin/dashboard" class="text-white/90 hover:text-white text-sm font-medium">Dashboard</a>
              
              <!-- Relationships dropdown -->
              <div x-data="{ open: false }" @keydown.escape.window="open = false" class="relative">
                <button @click="open = !open" :aria-expanded="open"
                        class="text-white/90 hover:text-white text-sm font-medium flex items-center gap-1">
                  Relationships
                  <svg class="w-3.5 h-3.5 mt-0.5 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div x-show="open"
                     x-transition:enter="transition ease-out duration-100"
                     x-transition:enter-start="transform opacity-0 scale-95"
                     x-transition:enter-end="transform opacity-100 scale-100"
                     x-transition:leave="transition ease-in duration-75"
                     x-transition:leave-start="transform opacity-100 scale-100"
                     x-transition:leave-end="transform opacity-0 scale-95"
                     @click.away="open = false"
                     x-cloak
                     class="absolute top-full left-0 mt-1.5 w-48 bg-white rounded-xl shadow-lg py-1.5 z-50 border border-gray-100">
                  <a href="/admin/volunteers" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Volunteers</a>
                  <a href="/admin/agencies" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Agencies</a>
                </div>
              </div>

              <!-- Applications/Assessments/Feedback dropdown -->
              <div x-data="{ open: false }" @keydown.escape.window="open = false" class="relative">
                <button @click="open = !open" :aria-expanded="open"
                        class="text-white/90 hover:text-white text-sm font-medium flex items-center gap-1">
                  Applications
                  <svg class="w-3.5 h-3.5 mt-0.5 transition-transform" :class="open ? 'rotate-180' : ''" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div x-show="open"
                     x-transition:enter="transition ease-out duration-100"
                     x-transition:enter-start="transform opacity-0 scale-95"
                     x-transition:enter-end="transform opacity-100 scale-100"
                     x-transition:leave="transition ease-in duration-75"
                     x-transition:leave-start="transform opacity-100 scale-100"
                     x-transition:leave-end="transform opacity-0 scale-95"
                     @click.away="open = false"
                     x-cloak
                     class="absolute top-full left-0 mt-1.5 w-52 bg-white rounded-xl shadow-lg py-1.5 z-50 border border-gray-100">
                  <a href="/admin/vol-applications" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Volunteer Applications</a>
                  <a href="/admin/dog-applications" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Dog Applications</a>
                  <a href="/admin/assessments" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Assessments</a>
                  <hr class="my-1 border-gray-100" />
                  <a href="/admin/feedback" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Feedback</a>
                </div>
              </div>
              <a href="/admin/gallery" class="text-white/90 hover:text-white text-sm font-medium">Gallery</a>
              <a href="/admin/shifts/new" class="text-white/90 hover:text-white text-sm font-medium">New Shift</a>
              <a href="/admin/calendar" title="Global calendar subscription"
                 class="text-white/70 hover:text-white transition-colors p-1 rounded-lg hover:bg-white/10">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </a>
            {% elif user.role == "agency_contact" %}
              <a href="/agency/dashboard" class="text-white/90 hover:text-white text-sm font-medium">Dashboard</a>
              <a href="/agency/team" class="text-white/90 hover:text-white text-sm font-medium">My Team</a>
              <a href="/agency/calendar" title="Agency calendar subscription"
                 class="text-white/70 hover:text-white transition-colors p-1 rounded-lg hover:bg-white/10">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </a>
            {% endif %}
          {% endif %}
        </div>

        <!-- Right side: theme toggle + notifications + avatar -->
        <div class="flex items-center gap-3">

          <!-- Theme toggle: cycles light → dark → system -->
          <div x-data="{
            theme: (document.cookie.match(/(?:^|;\s*)theme=([^;]*)/) || [])[1] || 'light',
            cycle() {
              var order = ['light', 'dark', 'system'];
              this.theme = order[(order.indexOf(this.theme) + 1) % 3];
              this.apply();
              this.persist();
            },
            apply() {
              var dark = this.theme === 'dark' ||
                (this.theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
              document.documentElement.classList.toggle('dark', dark);
            },
            persist() {
              document.cookie = 'theme=' + this.theme + '; path=/; max-age=31536000; SameSite=Lax';
              fetch('/api/v1/preferences/theme', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ theme: this.theme })
              }).catch(function(){});
            }
          }" x-init="
            if (theme === 'system') {
              window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', function() { apply(); });
            }
          ">
            <button @click="cycle()"
                    :title="{ light: 'Light mode', dark: 'Dark mode', system: 'System preference' }[theme]"
                    class="p-1.5 rounded-lg text-white/80 hover:text-white hover:bg-white/15 transition-colors">
              <!-- Sun: light mode -->
              <svg x-show="theme === 'light'" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z"/>
              </svg>
              <!-- Moon: dark mode -->
              <svg x-show="theme === 'dark'" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
              </svg>
              <!-- Monitor: system preference -->
              <svg x-show="theme === 'system'" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </button>
          </div>

          {% if user %}
            <!-- Notification bell -->
            {% if user.role == "admin" %}
              <a href="/admin/dashboard" class="relative text-white">
            {% elif user.role == "agency_contact" %}
              <a href="/agency/dashboard" class="relative text-white">
            {% else %}
              <a href="/volunteer/messages" class="relative text-white">
            {% endif %}
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
              </svg>
              <!-- Unread count badge — fetched on load + polled every 60s -->
              <span
                class="hidden"
                hx-get="/api/notifications/unread-count"
                hx-trigger="load, every 60s"
                hx-swap="outerHTML"
              ></span>
            </a>

            <!-- User menu -->
            <div x-data="{ open: false }" 
                 @keydown.escape.window="open = false"
                 class="relative">
              <button @click="open = !open" 
                      :aria-expanded="open"
                      class="flex items-center gap-2 text-white">
                <div class="w-8 h-8 rounded-full bg-sunshine-300 flex items-center justify-center text-sunshine-900 font-bold text-sm">
                  {{ user.display_name | default(value=user.email) | badge_initial }}
                </div>
              </button>
              <div x-show="open" 
                   x-transition:enter="transition ease-out duration-100"
                   x-transition:enter-start="transform opacity-0 scale-95"
                   x-transition:enter-end="transform opacity-100 scale-100"
                   x-transition:leave="transition ease-in duration-75"
                   x-transition:leave-start="transform opacity-100 scale-100"
                   x-transition:leave-end="transform opacity-0 scale-95"
                   @click.away="open = false"
                   x-cloak
                   class="absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg py-1 z-50 border border-gray-100">
                {% if user.role == "admin" %}
                  <a href="/admin/profile" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Profile</a>
                  <hr class="my-1" />
                  <a href="/admin/users" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">👥 User Management</a>
                  <a href="/admin/site" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">⚙️ Site Admin</a>
                  <a href="/admin/system" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">🔧 System</a>
                {% elif user.role == "agency_contact" %}
                  <a href="/agency/profile" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Profile</a>
                {% else %}
                  {% if volunteer_application_status %}
                    <a href="/apply/status" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">My Application</a>
                  {% else %}
                    <a href="/volunteer/profile" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Profile</a>
                  {% endif %}
                {% endif %}
                <hr class="my-1" />
                <form action="/auth/logout" method="post" class="block">
                  <button class="w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-50">Sign out</button>
                </form>
              </div>
            </div>
          {% else %}
            <a href="/auth/login"
               class="bg-white text-sunshine-700 font-semibold px-4 py-2 rounded-lg text-sm hover:bg-sunshine-50 transition-colors">
              Sign in
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </nav>

  <!-- Toast notification container (populated by HTMX OOB swaps) -->
  <div id="toast-container"></div>

  <!-- Volunteer survey prompt banner (loaded via HTMX on each page) -->
  {% if user and user.role == "volunteer" and not volunteer_application_status %}
  <div hx-get="/volunteer/survey-banner" hx-trigger="load" hx-swap="outerHTML"></div>
  {% endif %}

  <!-- Flash messages -->
  {% if flash and not flash.message is starting_with("SHIFT_CREATED:") %}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4"
         x-data="{ show: true }" x-show="show">
      <div class="rounded-lg p-4 flex items-center justify-between
                  {% if flash.kind == 'error' %}bg-red-50 border border-red-200 text-red-800
                  {% elif flash.kind == 'success' %}bg-green-50 border border-green-200 text-green-800
                  {% else %}bg-blue-50 border border-blue-200 text-blue-800{% endif %}">
        <span>{{ flash.message }}</span>
        <button @click="show = false" class="ml-4 opacity-60 hover:opacity-100">✕</button>
      </div>
    </div>
  {% endif %}

  <!-- Main content -->
  <main id="page-main" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    {% block content %}{% endblock %}
  </main>

  <!-- Footer -->
  <footer class="mt-16 border-t border-gray-200 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-gray-400">
      <p>Sunshine Therapy Dogs &mdash; brightening days across Southern Ontario</p>
    </div>
  </footer>

  <!-- Service Worker Registration -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js', { scope: '/' })
          .then(registration => {
            console.log('[Service Worker] Registration successful with scope: ', registration.scope);
          })
          .catch(err => {
            console.error('[Service Worker] Registration failed: ', err);
          });
      });
    }
  </script>

  {% block scripts %}{% endblock %}

  <!-- Debug: Verify Alpine.js is working -->
  <script>
    document.addEventListener('alpine:initialized', () => {
      console.log('[Alpine.js] Initialized successfully');
    });
    // Check if Alpine is loaded after a short delay
    setTimeout(() => {
      if (window.Alpine) {
        console.log('[Alpine.js] Version:', window.Alpine.version || 'unknown');
      } else {
        console.error('[Alpine.js] NOT LOADED - check script src and integrity hash');
      }
    }, 100);
  </script>
</body>
</html>
